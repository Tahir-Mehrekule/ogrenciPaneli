# ─── UniTrack AI Backend Ortam Değişkenleri ──────────────────────────────────
# Bu dosyayı kopyala: cp .env.example .env
# Üretim ortamında tüm değerleri değiştir.

# ── Veritabanı ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/unitrack

# ── JWT Authentication ────────────────────────────────────────────────────────
# En az 32 karakter, rastgele üret: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_MIN_32_CHARS_RANDOM_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── OpenRouter AI API ─────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Uygulama Ayarları ─────────────────────────────────────────────────────────
APP_NAME=UniTrack AI
APP_VERSION=1.0.0
# ÖNEMLİ: Production'da False yap
DEBUG=False

# ── CORS (virgülle ayrılmış origin listesi) ───────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006

# ── MinIO (S3 Uyumlu Dosya Depolama) ─────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_USER
MINIO_SECRET_KEY=CHANGE_ME_MINIO_PASSWORD
MINIO_BUCKET_NAME=unitrack-files
MINIO_SECURE=False
